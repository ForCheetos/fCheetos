label(code)
label(return)
label(loop_start)
alloc(hitCount,4) //; defined as 4 bytes


newmem:
  // Save flags first
  pushfq

  // Save non-parameter registers
  push rax
  push rbx
  push rsi
  push rdi
  push rbp
  push r10
  push r11
  push r12
  push r13
  push r14
  push r15


  // IMPORTANT: DON'T push rcx, rdx, r8, r9 yet - they're our parameters!
  // We'll save them inside the loop instead

  // Use r15 as our loop counter (safe register)
  mov r15d,[hitCount]

loop_start:
  cmp r15, 0
  jle code

  // Save the 4 parameters before each call
  // because the function might modify them

  //; if its enemies attacking, then skip the function
  cmp rdx,[base+4a98610]
  je code

  push rcx
  push rdx
  push r8
  push r9
  call base+8A18820 //; DoHit
  pop r9
  pop r8
  pop rdx
  pop rcx

  dec r15
  jmp loop_start

code:
  // restore all saved registers
  pop r15
  pop r14
  pop r13
  pop r12
  pop r11
  pop r10
  pop rbp
  pop rdi
  pop rsi
  pop rbx
  pop rax
  popfq

  jmp return

  hitCount:
  dd 5

address:
  jmp newmem
  nop


return:
registersymbol(hitCount)
[DISABLE]
address:
  db bytes
dealloc(*)
unregistersymbol(*)
