                      <Description>"_st3 ( don't touch )"</Description>
                      <VariableType>Auto Assembler Script</VariableType>
                      <AssemblerScript>define(address,base+1AC02BE)
define(bytes,F3 44 0F 58 79 14)

[ENABLE]

assert(address,bytes)
alloc(GetAsyncKeyStateSafe,$100)
alloc(newmem,$1000,base+1AC02BE)
label(code)
label(return)
label(Speed)

GetAsyncKeyStateSafe:
sub rsp,28
call user32.GetAsyncKeyState
add rsp,28
ret

newmem:
cmp [base+48BFD88],0 //; if ( game not in Focus ) then no work xD
je return

push rcx
push rdx
push r8
push r9
push r10
push r11
mov rcx,0x57
call GetAsyncKeyStateSafe
test rax,rax
pop r11
pop r10
pop r9
pop r8
pop rdx
pop rcx
jz code

  push rax
  mov rax,base+4e19968
  test rax,rax
  jz InstantEND
  mov rax,[rax]
  test rax,rax
  jz InstantEND

  mov rax,[rax+a0]
  test rax,rax
  jz InstantEND

  mov rax,[rax+70]
  test rax,rax
  jz InstantEND

  mov rax,[rax+30]
  test rax,rax
  jz InstantEND

  mov rax,[rax+210]
  test rax,rax
  jz InstantEND

  mov rax,[rax+50]
  test rax,rax
  jz InstantEND

  mov rax,[rax+188]
  test rax,rax
  jz InstantEND

  mov rax,[rax+10]
  test rax,rax
  jz InstantEND

  mov rax,[rax+70]
  test rax,rax
  jz InstantEND

  push rbx
  mov rbx,SSCamera
  test rbx,rbx
  jz InstantEND

  mov rbx,[rbx]
  test rbx,rbx
  jz InstantEND

  fld qword ptr [rbx]      // Load Yaw
  fstp dword ptr [YawRadian]

  fld qword ptr [rbx+8]  // Load Pitch
  fstp dword ptr [PitchRadian]

//;X
  fld dword ptr [YawRadian]
  fcos
  fmul dword ptr [Speed]
  fstp dword ptr [DeltaX]

//;Y
  fld dword ptr [PitchRadian]
  fsin
  fmul dword ptr [Speed]
  fstp dword ptr [DeltaY]

//;Z
  fld dword ptr [YawRadian]
  fsin
  fmul dword ptr [Speed]
  fstp dword ptr [DeltaZ]

//;X
  fld dword ptr [rax+A0]
  fsub dword ptr [DeltaX]
  fstp dword ptr [rax+A0]
//;Y
  fld dword ptr [rax+A4]
  fsub dword ptr [DeltaY]
  fstp dword ptr [rax+A4]
//;Z
  fld dword ptr [rax+A8]
  fsub dword ptr [DeltaZ]
  fstp dword ptr [rax+A8]

  InstantEND:
  pop rbx
  pop rax
code:
  addss xmm15,[rcx+14]
  jmp return

  Speed:
  dd (float)0.1

YawRadian:
dq 00

PitchRadian:
dq 00

DeltaX:
dq 00

DeltaZ:
dq 00

DeltaY:
dq 00

address:
