label(code)
label(return)
label(debugCam)
label(Straf YawRadian PitchRadian)


//; Disabling PlayerMovement
base+1af6ffb:
db 90 90 90 90 90
base+1af7000:
db 90 90 90 90 90
base+1af7005:
db 90 90 90 90 90


//; Disabling Official Game Camera Render
base+cadecba:
db 90 90 90 90 90 90  //--&gt; 89 86 B8 03 00 00
base+cadecc5:
db 90 90 90 90 90 90 90 //--&gt; 48 89 86 B0 03 00 00

newmem:
push rdx
lea rdx,[rsi+30]
mov [debugCam],rdx
pop rdx

  cmp [base+48BFD88],0 //; if ( game not in Focus ) then no work xD
  je return

  fld qword ptr [rsi+30-E8]      // Load Yaw
  fstp qword ptr [YawRadian]

  fld qword ptr [rsi+30-E0]  // Load Pitch
  fstp qword ptr [PitchRadian]

  push rcx
  mov rcx, 57  //; VK_W (Forward movement)
  call GetAsyncKeyState //win32u.NtUser
  test eax, eax
  pop rcx
  jz @f

//;X
  fld qword ptr [YawRadian]
  fcos
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaX]

//;Y
  fld qword ptr [PitchRadian]
  fsin
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaY]

//;Z
  fld qword ptr [YawRadian]
  fsin
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaZ]

//;X
  fld qword ptr [rsi+30]
  fsub qword ptr [DeltaX]
  fstp qword ptr [rsi+30]
//;Y
  fld qword ptr [rsi+38]
  fsub qword ptr [DeltaY]
  fstp qword ptr [rsi+38]
//;Z
  fld qword ptr [rsi+40]
  fsub qword ptr [DeltaZ]
  fstp qword ptr [rsi+40]


  @@:
  push rcx
  mov rcx, 53  //; VK_S
  call GetAsyncKeyState //win32u.NtUser
  test eax, eax
  pop rcx
  jz @f

//;X
  fld qword ptr [YawRadian]
  fcos
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaX]

//;Y
  fld qword ptr [PitchRadian]
  fsin
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaY]

//;Z
  fld qword ptr [YawRadian]
  fsin
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaZ]

//;X
  fld qword ptr [rsi+30]
  fadd qword ptr [DeltaX]
  fstp qword ptr [rsi+30]
//;Y
  fld qword ptr [rsi+38]
  fadd qword ptr [DeltaY]
  fstp qword ptr [rsi+38]
//;Z
  fld qword ptr [rsi+40]
  fadd qword ptr [DeltaZ]
  fstp qword ptr [rsi+40]

  @@:
  push rcx
  mov rcx, 0x41  //; VK_A
  call GetAsyncKeyState //win32u.NtUser
  test eax, eax
  pop rcx
  jz @f

  //; Left Side

//;X
  fld qword ptr [YawRadian]
  fadd qword ptr [PiOverTwo]
  fcos
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaX]


//;Z
  fld qword ptr [YawRadian]
  fadd qword ptr [PiOverTwo]
  fsin
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaZ]

//;X
  fld qword ptr [rsi+30]
  fsub qword ptr [DeltaX]
  fstp qword ptr [rsi+30]


//;Z
  fld qword ptr [rsi+40]
  fsub qword ptr [DeltaZ]
  fstp qword ptr [rsi+40]

  @@:
  push rcx
  mov rcx, 0x44  //; VK_D
  call GetAsyncKeyState //win32u.NtUser
  test eax, eax
  pop rcx
  jz @f

  //; Right Side

//;X
  fld qword ptr [YawRadian]
  fsub qword ptr [PiOverTwo]
  fcos
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaX]


//;Z
  fld qword ptr [YawRadian]
  fsub qword ptr [PiOverTwo]
  fsin
  fmul qword ptr [Speed]
  fstp qword ptr [DeltaZ]

//;X
  fld qword ptr [rsi+30]
  fsub qword ptr [DeltaX]
  fstp qword ptr [rsi+30]


//;Z
  fld qword ptr [rsi+40]
  fsub qword ptr [DeltaZ]
  fstp qword ptr [rsi+40]

@@:
 push rcx
 mov rcx,0x11
 call GetAsyncKeyState
 test eax,eax
 pop rcx
 jnz SlowDown

@@:
 push rcx
 mov rcx,0x10
 call GetAsyncKeyState
 test eax,eax
 pop rcx
 jnz SpeedUp

fld qword ptr [BackUpS1]
fstp qword ptr [Speed]

